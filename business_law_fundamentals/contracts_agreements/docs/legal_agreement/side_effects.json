{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "review": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "approve": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "approved"
      }
    },
    {
      "type": "create_record",
      "target_doc": "legal_review_case",
      "values": {
        "title": {
          "$template": "Legal Review Case for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "LEGAL_REVIEW_CASE-{reference_no|id}"
        }
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ],
  "execute": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "executed"
      }
    }
  ],
  "issue": [
    {
      "type": "create_record",
      "target_doc": "legal_review_case",
      "values": {
        "title": {
          "$template": "Legal Review Case for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "LEGAL_REVIEW_CASE-{reference_no|id}"
        }
      }
    }
  ]
}
